# ──────────────────────────────────────────────────────
# Chart Vision AI - 환경변수 예시
# 이 파일을 복사해서 .env.local 을 만드세요:
#   cp .env.local.example .env.local
# ──────────────────────────────────────────────────────

# ── AI API ─────────────────────────────────────────────
# [선택] OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# [선택] Groq
# GROQ_API_KEY=gsk_...

# [선택] Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── NextAuth (필수) ─────────────────────────────────────
# openssl rand -base64 32 으로 생성
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── 관리자 계정 ─────────────────────────────────────────
# 최초 서버 실행 시 자동으로 관리자 계정이 생성됩니다.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=strongpassword123!

# ── 크레딧 설정 ─────────────────────────────────────────
# 신규 가입 시 자동 지급되는 무료 크레딧 수
INITIAL_CREDITS=10
NEXT_PUBLIC_INITIAL_CREDITS=10

# ── 사이트 설정 ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── 레거시 (선택, 삭제 가능) ─────────────────────────────
# 기존 비밀번호 게이트 (회원 시스템으로 대체됨)
# ACCESS_PASSWORD=your-secret-password
# NEXT_PUBLIC_ACCESS_PASSWORD_REQUIRED=false
